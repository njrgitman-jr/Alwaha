# --- Server ---
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# --- Admin bootstrap (used on first db:seed) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# --- Database (SQL Server) ---
# Replace placeholders with values from your DB. NEVER commit real values.
DB_HOST=localhost
DB_INSTANCE=SQLEXPRESS
DB_PORT=1433
DB_NAME=DAC_Website
DB_USER=swo_user
DB_PASSWORD=__SET_REAL_PASSWORD_HERE__
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# --- Offline fallback ---
# If true, server skips DB and serves data from db/seed-data.json (good for demos).
USE_JSON_FALLBACK=true

# --- CORS ---
CLIENT_ORIGIN=http://localhost:5173
