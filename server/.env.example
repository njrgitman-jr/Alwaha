# --- Server ---
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string

# --- Admin bootstrap (used on first db:seed) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# =====================================================================
# --- Database ---
# Two modes. Set ONE of them depending on where this is running.
# =====================================================================

# MODE 1 — Local development (SQL Server Express, named instance)
# Use this on your machine. Leave DATABASE_URL blank/unset below.
DB_HOST=localhost
DB_INSTANCE=SQLEXPRESS
DB_PORT=1433
DB_NAME=Alwaha_Water
DB_USER=alwaha_user
DB_PASSWORD=__SET_REAL_PASSWORD_HERE__
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# MODE 2 — Deployment (Render, Azure SQL, or any managed SQL Server)
# Set this instead when deploying. If DATABASE_URL is set, it overrides
# all DB_* vars above automatically (see server/knexfile.ts).
# Format: mssql://user:password@host:port/database?encrypt=true
# DATABASE_URL=mssql://user:password@your-host:1433/Alwaha_Water?encrypt=true

# --- Offline fallback ---
# If true, server skips DB and serves data from db/seed-data.json (good for demos).
USE_JSON_FALLBACK=false

# --- CORS ---
# Comma-separated list is supported (local + staging + production).
# In production, any https://alwaha*.vercel.app preview URL is also auto-allowed.
CLIENT_ORIGIN=http://localhost:5173
